#compdef worktree

local -a _worktree_commands
_worktree_commands=(
  'new:Create new worktree folder only'
  'setup:Run setup script in worktree'
  'diff:Open nvim Diffview against main'
  'destroy:Remove worktree and clean up'
  'open:Open worktree using tmuxinator template'
)

_worktree() {
  local curcontext="$curcontext" state

  _arguments -C \
    '1:command:->command' \
    '2:argument:->arg' \
    && return 0

  case $state in
    command)
      _describe 'command' _worktree_commands
      ;;
    arg)
      case $words[2] in
        new)
          _message 'feature description'
          ;;
        setup|diff|destroy|open)
          _worktree_directories
          ;;
      esac
      ;;
    *)
      _message 'no more arguments'
      ;;
  esac
}

_worktree_directories() {
  local worktrees_dir="./worktrees"
  local -a directories

  [[ -d "$worktrees_dir" ]] || return 0

  directories=(${(@f)$(command ls -1 "$worktrees_dir" 2>/dev/null)})
  (( ${#directories[@]} )) || return 0

  compadd -a directories
}

_worktree "$@"
