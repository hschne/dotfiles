{
  "lastChangelogVersion": "0.52.12",
  "defaultProvider": "anthropic",
  "defaultModel": "claude-sonnet-4-5",
  "theme": "tokyo-night",
  "packages": [
    "npm:pi-mcp-adapter"
  ],
  "enabledModels": [
    "google-gemini-cli/gemini-3-flash-preview",
    "anthropic/claude-opus-4-5",
    "anthropic/claude-opus-4-6",
    "google/gemini-3-flash-preview"
  ],
  "formatters": {
    "standardrb": {
      "command": [
        "standardrb",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".rb",
        ".rake",
        ".gemspec",
        ".ru"
      ]
    },
    "herb": {
      "command": [
        "herb-format",
        "$FILE"
      ],
      "extensions": [
        ".erb",
        ".html.erb"
      ]
    },
    "prettier": {
      "command": [
        "npx",
        "prettier",
        "--write",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".html",
        ".css",
        ".scss",
        ".json",
        ".yaml",
        ".yml",
        ".md",
        ".mdx"
      ]
    },
    "shfmt": {
      "command": [
        "shfmt",
        "-w",
        "$FILE"
      ],
      "extensions": [
        ".sh",
        ".bash"
      ]
    }
  },
  "lsp": {
    "servers": {
      "typescript": {
        "command": [
          "typescript-language-server",
          "--stdio"
        ],
        "extensions": [
          ".ts",
          ".tsx",
          ".js",
          ".jsx",
          ".mjs",
          ".cjs",
          ".mts",
          ".cts"
        ],
        "rootPatterns": [
          "tsconfig.json",
          "jsconfig.json",
          "package.json"
        ]
      },
      "ruby": {
        "command": [
          "ruby-lsp"
        ],
        "extensions": [
          ".rb",
          ".rake",
          ".gemspec",
          ".ru",
          ".erb"
        ],
        "rootPatterns": [
          "Gemfile",
          ".ruby-version",
          "Gemfile.lock"
        ]
      },
      "svelte": {
        "command": [
          "svelteserver",
          "--stdio"
        ],
        "extensions": [
          ".svelte"
        ],
        "rootPatterns": [
          "svelte.config.js",
          "svelte.config.ts",
          "package.json"
        ]
      },
      "markdown": {
        "command": [
          "marksman",
          "server"
        ],
        "extensions": [
          ".md",
          ".markdown"
        ],
        "rootPatterns": [
          ".marksman.toml"
        ]
      },
      "yaml": {
        "command": [
          "yaml-language-server",
          "--stdio"
        ],
        "extensions": [
          ".yaml",
          ".yml"
        ],
        "rootPatterns": []
      },
      "herb": {
        "command": [
          "herb-language-server",
          "--stdio"
        ],
        "extensions": [
          ".erb",
          ".html.erb"
        ],
        "rootPatterns": []
      }
    }
  },
  "defaultThinkingLevel": "medium"
}